#!/usr/bin/env bash
set -euo pipefail

BACKUP_HOST="{{ hostvars[backup_server_inventory_host].ansible_host | default(backup_server_inventory_host) }}"
BACKUP_ROOT="{{ backup_root }}"
KEY="{{ backup_restore_ssh_key_path }}"
DB_NAME="{{ db_name }}"
FORCE_FILE="{{ backup_restore_force_file }}"
WORK_DIR="/var/lib/logistia-backup"
RESTORE_FILE="$WORK_DIR/latest.sql.gz"
LOG_FILE="/var/log/logistia-restore-postgres.log"

mkdir -p "$WORK_DIR"

{
  echo "[$(date --iso-8601=seconds)] Checking PostgreSQL restore from backup"

  if [ ! -f "$FORCE_FILE" ]; then
    EXISTING_ROWS="$(runuser -u postgres -- psql -d "$DB_NAME" -Atqc "SELECT count(*) FROM mail_users;" 2>/dev/null || echo 0)"
    if [ "$EXISTING_ROWS" != "0" ]; then
      echo "Mail database already contains data, restore skipped"
      exit 0
    fi
  fi

  scp -i "$KEY" -o BatchMode=yes -o StrictHostKeyChecking=accept-new \
    root@"$BACKUP_HOST":"$BACKUP_ROOT/postgres/latest.sql.gz" "$RESTORE_FILE"

  gunzip -c "$RESTORE_FILE" | runuser -u postgres -- psql
  rm -f "$FORCE_FILE"
  echo "PostgreSQL restore completed"
} >> "$LOG_FILE" 2>&1
