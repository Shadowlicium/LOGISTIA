<?php
// Generated by Ansible.

declare(strict_types=1);

define('DB_HOST', '{{ logistia_db_host }}');
define('DB_PORT', '{{ logistia_db_port }}');
define('DB_NAME', '{{ logistia_db_name }}');
define('DB_USER', '{{ logistia_db_user }}');
define('DB_PASS', '{{ logistia_db_password }}');

function getDB(): PDO
{
    $dsn = 'pgsql:host=' . DB_HOST . ';port=' . DB_PORT . ';dbname=' . DB_NAME;

    try {
        $pdo = new PDO($dsn, DB_USER, DB_PASS);
        $pdo->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);
        $pdo->setAttribute(PDO::ATTR_DEFAULT_FETCH_MODE, PDO::FETCH_ASSOC);
        return $pdo;
    } catch (PDOException $e) {
        error_log('LOGISTIA DB connection error: ' . $e->getMessage());
        http_response_code(500);
        die('Erreur connexion BDD.');
    }
}
